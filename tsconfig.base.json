{
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@shelfr/ui": ["libs/ui/src/index.ts"],
      "@shelfr/shared": ["libs/shared/src/index.ts"]
    },
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "strict": true
  },
  "exclude": ["node_modules", "tmp", "dist"]
}
