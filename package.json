{
  "name": "@shelfr/source",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start": "nx serve web",
    "build": "nx build web",
    "build:extension": "nx build extension",
    "zip:extension": "nx build extension && cd dist/extension && zip -r ../../shelfr-extension.zip . && echo 'Created shelfr-extension.zip'",
    "dev:extension": "nx dev extension",
    "dev": "nx serve web",
    "deploy:functions": "npx supabase functions deploy scrape-url --project-ref juimdgzjknasimubewhp --no-verify-jwt",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "nx": {
    "includedScripts": []
  },
  "dependencies": {
    "@remixicon/react": "^4.6.0",
    "@supabase/supabase-js": "^2.49.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "6.30.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "22.6.4",
    "@nx/eslint-plugin": "22.6.4",
    "@nx/js": "22.6.4",
    "@nx/react": "22.6.4",
    "@nx/vite": "22.6.4",
    "@nx/web": "22.6.4",
    "@nx/workspace": "22.6.4",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/chrome": "^0.1.40",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "10.4.13",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-storybook": "^10.3.5",
    "husky": "^9.1.7",
    "jiti": "2.4.2",
    "lint-staged": "^16.4.0",
    "nx": "22.6.4",
    "pg": "^8.20.0",
    "postcss": "8.4.38",
    "prettier": "~3.6.2",
    "storybook": "^10.3.5",
